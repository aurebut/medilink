NODE_ENV=development
PORT=4000
API_PUBLIC_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medilink?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/medilink?schema=public"

SESSION_COOKIE_NAME=medilink_session
SESSION_SECRET=change-me-in-production
SESSION_MAX_AGE_DAYS=30

# Email provider. If RESEND_API_KEY is empty, emails are logged and marked as SENT in DB.
RESEND_API_KEY=
EMAIL_FROM="Médilink <no-reply@medilink.local>"

# Storage mode.
# Local dev: STORAGE_PROVIDER=local stores files under LOCAL_STORAGE_DIR.
# Production with Supabase Storage: create S3 access keys in Supabase, set STORAGE_PROVIDER=s3,
# S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3 and S3_BUCKET=<private-bucket>.
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=storage/uploads
STORAGE_SIGNING_SECRET=change-me-in-production
S3_REGION=auto
S3_ENDPOINT=
S3_BUCKET=medilink-private
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
SIGNED_URL_TTL_SECONDS=300

# ANS Annuaire Sante FHIR v2. Required for RPPS/FINESS automatic verification.
ANS_FHIR_BASE_URL=https://gateway.api.esante.gouv.fr/fhir/v2
ANS_API_KEY=

# Stripe billing for establishment mission publication.
# Create one recurring EUR price at 59.99/month and one one-time EUR price at 39.99.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESTABLISHMENT_MONTHLY=
STRIPE_PRICE_MISSION_PUBLICATION=
