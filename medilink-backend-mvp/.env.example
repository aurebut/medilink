NODE_ENV=development
PORT=4000
API_PUBLIC_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medilink?schema=public"

SESSION_COOKIE_NAME=medilink_session
SESSION_SECRET=change-me-in-production
SESSION_MAX_AGE_DAYS=30

# Email provider. If RESEND_API_KEY is empty, emails are logged and marked as SENT in DB.
RESEND_API_KEY=
EMAIL_FROM="Médilink <no-reply@medilink.local>"

# Storage mode. For MVP local dev you can leave STORAGE_PROVIDER=mock.
# In production, set STORAGE_PROVIDER=s3 and fill the S3-compatible config.
STORAGE_PROVIDER=mock
S3_REGION=auto
S3_ENDPOINT=
S3_BUCKET=medilink-private
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
SIGNED_URL_TTL_SECONDS=300
